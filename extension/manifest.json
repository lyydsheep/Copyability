{
  "manifest_version": 3,
  "name": "Copyability",
  "version": "0.2.0",
  "description": "Turn a Supported Selection in a Feishu wiki document into a Plain-text Copy Result.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://my.feishu.cn/wiki/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
